{
  "name": "gog-email-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm format:check && oxlint --deny-warnings .",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "build": "wrangler deploy --dry-run",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260607.1",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "packageManager": "pnpm@10.33.2"
}
